# Copy to .env and fill in your keys. Never commit .env.

# REQUIRED: free email signup at https://openrouter.ai/keys (no credit card).
# Class default model is openai/gpt-oss-120b:free.
# Free tier = 20 requests/minute and 50 requests/day PER MODEL. If you hit a
# 429, swap the `model=` line in the notebook to qwen/qwen3-coder:free,
# deepseek/deepseek-r1-0528:free, or z-ai/glm-4.6:free; each has its own
# separate quota pool.
OPENROUTER_API_KEY=

# OPTIONAL: only needed for Ex 5. Sign up at https://console.anthropic.com
ANTHROPIC_API_KEY=

# OPTIONAL: Gemini swap. Free at https://aistudio.google.com/apikey
# Note: Gemini free tier is only 20 RPD per model (Apr 2026 post-cuts), which
# is why this is no longer the class default. Useful for provider comparison.
GOOGLE_API_KEY=

# OPTIONAL: Ex 4 observability. Free at https://smith.langchain.com
LANGSMITH_API_KEY=
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=w10-hands-on
